# JARVIS environment template (copy to .env and fill in values)

# --- Backend API ---
API_HOST=127.0.0.1
API_PORT=8000
API_REQUIRE_AUTH=false
API_DEV_TOKEN=

# --- Executor link (backend → executor) ---
EXECUTOR_BASE_URL=http://127.0.0.1:8001
EXECUTOR_API_KEY=
EXECUTOR_TIMEOUT_SECONDS=120
EXECUTOR_INLINE_WAIT_SECONDS=0.25

# --- Orchestrator (runtime planning, schema 2.0) ---
ORCHESTRATOR_DISABLED=false
ORCHESTRATOR_PROVIDER=gemini
ORCHESTRATOR_MODEL=gemini-2.0-flash-lite
ORCHESTRATOR_CATALOG_TTL_SECONDS=60
ORCHESTRATOR_MAX_STEPS=8
GOOGLE_GEMINI_KEY=

# --- Chat (general conversation; parser uses orchestrator by default) ---
CHAT_PRIMARY_PROVIDER=huggingface
CHAT_TIMEOUT_SECONDS=45
HF_SPACE_ID=
HF_SPACE_LINK=
HF_API_NAME=/respond
HF_TOKEN=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b

# --- Executor service ---
EXECUTOR_API_HOST=127.0.0.1
EXECUTOR_API_PORT=8001
EXECUTOR_API_REQUIRE_AUTH=false
EXECUTOR_API_DEV_TOKEN=
EXECUTOR_ALLOWLIST_PATH=
EXECUTOR_ASSIGNMENT_LOCATION=
EXECUTOR_PROJECT_LOCATION=
EXECUTOR_OLLAMA_BASE_URL=http://127.0.0.1:11434
EXECUTOR_OLLAMA_MODEL=llama3.2:1b

# --- OAuth / external APIs ---
Spotify_Client_ID=
Spotify_Client_Secret=
Spotify_Redirect_URI=
GCR_CREDENTIALS_JSON=
GCR_REDIRECT_URI=
Youtube_Data_API_V3=
Google_Gemini_Key=
Assignment_Location=
Project_Location=

# --- Speech ---
STT_WHISPER_MODEL_SIZE=small
TTS_PIPER_MODEL_PATH=backend/models/piper/en_US-lessac-medium.onnx
