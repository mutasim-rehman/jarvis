---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="mx-auto max-w-3xl px-6 pt-24 pb-16 lg:pt-28 lg:pb-20">
    <header class="mb-10 border-b border-white/10 pb-8">
      <p class="text-sm font-medium uppercase tracking-wider text-jarvis-muted">
        Legal
      </p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-sm text-jarvis-muted">Last updated: {lastUpdated}</p>
    </header>
    <div class="legal-prose">
      <slot />
    </div>
  </article>
</BaseLayout>
