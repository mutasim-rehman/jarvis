---
import BaseLayout from "../layouts/BaseLayout.astro";
import JarvisVisual from "../components/JarvisVisual.astro";
import { site } from "../config/site";

const modules = [
  {
    id: "chat",
    title: "Chat",
    body: "Natural conversation with intent-aware understanding, so quick questions and actionable commands coexist in one flow.",
  },
  {
    id: "automations",
    title: "Automations",
    body: "Build and run multi-step routines with safe execution boundaries, retries, and transparent status updates.",
  },
  {
    id: "memory",
    title: "Memory",
    body: "Preference-aware assistance that remembers context over time without turning the workspace into noise.",
  },
  {
    id: "devices",
    title: "Devices",
    body: "Pair desktop, mobile, and Pi clients under one account and control where each action is executed.",
  },
  {
    id: "integrations",
    title: "Integrations",
    body: "Connect services like Google and Spotify through OAuth, and extend capability handlers as your workflow grows.",
  },
  {
    id: "settings",
    title: "Settings",
    body: "A calm control center for voice style, personality preferences, data controls, and account security.",
  },
];
---

<BaseLayout title={site.name}>
  <section class="relative overflow-hidden px-6 pb-20 pt-12 lg:pt-16">
    <div class="glow-orb -left-28 top-10 h-80 w-80 bg-jarvis-accent/80" aria-hidden="true"></div>
    <div class="glow-orb -right-16 top-28 h-96 w-96 bg-jarvis-glow/60" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl">
      <p class="text-center text-sm font-medium uppercase tracking-[0.2em] text-jarvis-accent">
        Calm AI workspace
      </p>
      <h1 class="mx-auto mt-4 max-w-3xl text-center text-4xl font-semibold tracking-tight text-white sm:text-5xl">
        Your everyday assistant, designed to feel alive and focused
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-center text-lg text-jarvis-muted">
        JARVIS blends conversation, automations, and memory inside a clean dark workspace with soft motion and zero visual clutter.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="#chat"
          class="rounded-xl bg-jarvis-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-jarvis-accent-dim"
        >
          Enter workspace
        </a>
        <a
          href="/privacy"
          class="rounded-xl border border-white/15 px-6 py-3 text-sm font-medium text-jarvis-fg transition hover:border-white/30 hover:bg-white/5"
        >
          Privacy first
        </a>
      </div>
    </div>
  </section>

  <section id="chat" class="section-anchor px-6 pb-20">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[220px_1fr]">
      <aside class="glass-panel workspace-sidebar rounded-2xl p-4">
        <p class="px-3 text-xs uppercase tracking-wider text-jarvis-muted">Workspace</p>
        <nav class="mt-3 space-y-1.5">
          {modules.map((module, idx) => (
            <a
              href={`#${module.id}`}
              class:list={[
                "block rounded-xl px-3 py-2.5 text-sm transition",
                idx === 0
                  ? "bg-white/10 text-white"
                  : "text-jarvis-muted hover:bg-white/5 hover:text-white",
              ]}
            >
              {module.title}
            </a>
          ))}
        </nav>
      </aside>

      <article class="glass-panel rounded-3xl p-5 sm:p-7">
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <div>
            <p class="text-sm font-medium text-white">Conversation</p>
            <p class="text-xs text-jarvis-muted">Natural language control with execution awareness</p>
          </div>
          <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5">
            <span class="voice-dot"></span>
            <span class="text-xs text-jarvis-muted">Listening</span>
          </div>
        </div>

        <div class="mt-6 space-y-4">
          <div class="chat-row self-start rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-3 text-sm text-jarvis-muted">
            Good evening. Ready to continue where you left off?
          </div>
          <div class="chat-row ml-auto max-w-[92%] rounded-2xl border border-jarvis-accent/30 bg-jarvis-accent/15 px-4 py-3 text-sm text-white">
            Yes, open my DSA folder, launch VS Code, and pull pending Classroom assignments.
          </div>
          <div class="chat-row self-start rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-3 text-sm text-jarvis-muted">
            Planned 3 actions. Executing now with Google Classroom scope and local workspace context.
          </div>
        </div>

        <div class="mt-7 overflow-hidden rounded-2xl border border-white/10 bg-black/30">
          <JarvisVisual listening />
          <p class="border-t border-white/10 py-3 text-center text-xs uppercase tracking-widest text-jarvis-muted">
            Voice channel active
          </p>
        </div>
      </article>
    </div>
  </section>

  {modules.map((module) => (
    <section id={module.id} class="section-anchor border-t border-white/5 px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-6 lg:grid-cols-[1.1fr_1fr] lg:items-center">
          <div>
            <p class="text-xs uppercase tracking-widest text-jarvis-glow">Module</p>
            <h2 class="mt-2 text-3xl font-semibold text-white">{module.title}</h2>
            <p class="mt-4 max-w-2xl text-jarvis-muted">{module.body}</p>
          </div>
          <div class="glass-panel rounded-2xl p-5">
            <p class="text-sm font-medium text-white">Workspace behavior</p>
            <p class="mt-2 text-sm text-jarvis-muted">
              This module is designed with intelligent spacing, quiet transitions, and contextual visibility so power features stay approachable.
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="section-anchor border-y border-white/5 bg-black/20 px-6 py-20">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-semibold text-white">Advanced AI, everyday calm</h2>
      <p class="mx-auto mt-4 max-w-2xl text-jarvis-muted">
        JARVIS keeps the interface personal and productive, while legal and privacy controls remain transparent.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4 text-sm">
        <a href="/privacy" class="rounded-xl border border-white/15 px-5 py-2.5 text-jarvis-fg hover:bg-white/5">
          Privacy Policy
        </a>
        <a href="/terms" class="rounded-xl border border-white/15 px-5 py-2.5 text-jarvis-fg hover:bg-white/5">
          Terms of Service
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
