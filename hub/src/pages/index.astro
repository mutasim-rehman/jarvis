---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";

const sections = [
  {
    id: "chat",
    label: "Chat",
    title: "Conversation that\nunderstands intent",
    body: "Natural language with execution awareness. Quick questions and actionable commands coexist in one seamless, voice-first flow.",
    chips: ["Intent routing", "Context memory", "Voice + text"],
  },
  {
    id: "automations",
    label: "Automations",
    title: "Multi-step plans,\nsafely executed",
    body: "Structured task chains with retries, safe replanning, and transparent status streamed back on every action.",
    chips: ["DAG execution", "Auto-replan", "Live status"],
  },
  {
    id: "memory",
    label: "Memory",
    title: "Remembers\nwhat matters",
    body: "Preference-aware context that builds over time — adaptive to how you work, quiet when you don't need it.",
    chips: ["Per-user context", "Adaptive prefs", "Exportable"],
  },
  {
    id: "devices",
    label: "Devices",
    title: "One account,\nevery device",
    body: "Pair desktop, mobile, and Pi clients under one identity. Commands route to the right machine, every time.",
    chips: ["Secure pairing", "Remote execution", "QR onboarding"],
  },
  {
    id: "integrations",
    label: "Integrations",
    title: "Connected to\nyour workflow",
    body: "OAuth-based connections to Google, Spotify, and more — extensible capability handlers as your needs evolve.",
    chips: ["Google OAuth", "Spotify", "Custom handlers"],
  },
  {
    id: "settings",
    label: "Settings",
    title: "Personal\nby design",
    body: "Voice style, personality tuning, data controls, and account security — all in a calm, accessible panel.",
    chips: ["Personality", "Privacy controls", "OAuth mgmt"],
  },
];

// Stage height = 1 (hero) + 1 (morph) + sections.length (one per section) = 8 units of 100vh
const STAGE_UNITS = 2 + sections.length;
---

<BaseLayout title={site.name} heroHeader>
  <!-- ─── SCROLL STAGE ─────────────────────────────────────────── -->
  <div id="scroll-stage" style={`--stage-units: ${STAGE_UNITS}`}>
    <div id="sticky-shell">

      <!-- JARVIS 3D VISUAL (full → left panel) -->
      <div id="visual-panel">
        <iframe
          id="jarvis-iframe"
          src="/jarvis-visual.html"
          title="JARVIS visual"
          aria-hidden="true"
          tabindex="-1"
        ></iframe>
      </div>

      <!-- HERO TEXT: left side -->
      <div id="hero-left">
        <p class="hl-eyebrow">Execution system</p>
        <h1 class="hl-name">JARVIS</h1>
        <p class="hl-tagline">{site.tagline}</p>
      </div>

      <!-- HERO TEXT: right side -->
      <div id="hero-right">
        <p class="hr-desc">{site.shortDescription}</p>
        <a href="/waitlist" class="hr-cta">Get early access →</a>
        <p class="hr-hint">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
            <path d="M5 1v16M1 12l4 4 4-4" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Scroll to explore
        </p>
      </div>

      <!-- DOT NAV (appears after morph) -->
      <nav id="dot-nav" aria-label="Workspace sections">
        {sections.map((s, i) => (
          <button class="dot" data-idx={i} aria-label={s.label} title={s.label}></button>
        ))}
      </nav>

      <!-- CONTENT PANEL (right half, appears after morph) -->
      <div id="content-panel">
        <div id="sec-indicator">
          <span id="sec-num">01</span>
          <span class="sep">/</span>
          <span class="sec-total">{String(sections.length).padStart(2, "0")}</span>
        </div>

        {sections.map((s, i) => (
          <div class="c-card" data-idx={i}>
            <p class="c-label">{s.label}</p>
            <h2 class="c-title">{s.title}</h2>
            <p class="c-body">{s.body}</p>
            <ul class="c-chips">
              {s.chips.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- ─── TRUST / LEGAL (normal flow after stage) ─────────────── -->
  <section id="trust-section">
    <div class="ts-inner">
      <img src="/favicon.svg" width="40" height="40" alt="" class="ts-logo" />
      <h2 class="ts-title">Built on privacy and trust</h2>
      <p class="ts-body">
        Actions run only on devices you pair and commands you initiate. Your data is yours —
        exportable, deletable, never sold.
      </p>
      <div class="ts-links">
        <a href="/waitlist" class="ts-waitlist-btn">Join the waitlist</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
/* ── STAGE LAYOUT ────────────────────────────────────────────── */
#scroll-stage {
  height: calc(var(--stage-units, 8) * 100vh);
  position: relative;
}

#sticky-shell {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  background: #050505;
}

/* ── VISUAL PANEL ────────────────────────────────────────────── */
#visual-panel {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 100%;
  will-change: clip-path;
}

#visual-panel iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
  pointer-events: none;
}

/* ── HERO OVERLAYS ───────────────────────────────────────────── */
#hero-left,
#hero-right {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  pointer-events: none;
  will-change: opacity, transform;
}

/* Allow clicks on interactive elements inside overlays */
#hero-right a,
#hero-left a { pointer-events: auto; }

#hero-left  { left: 5%;  max-width: 260px; }
#hero-right { right: 5%; max-width: 260px; text-align: right; }

.hl-eyebrow {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-jarvis-accent);
  margin-bottom: 0.75rem;
}

.hl-name {
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #fff;
  line-height: 1;
  margin: 0 0 0.6rem;
}

.hl-tagline {
  font-size: clamp(0.8rem, 1.4vw, 1rem);
  color: var(--color-jarvis-muted);
  line-height: 1.5;
  margin: 0;
}

.hr-desc {
  font-size: clamp(0.8rem, 1.3vw, 0.9375rem);
  color: var(--color-jarvis-muted);
  line-height: 1.65;
  margin: 0 0 1rem;
}

.hr-cta {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0.45rem 1rem;
  border-radius: 999px;
  background: var(--color-jarvis-accent);
  color: #fff;
  text-decoration: none;
  pointer-events: auto;
  margin-bottom: 1.1rem;
  transition: background 0.2s, transform 0.15s;
}
.hr-cta:hover {
  background: var(--color-jarvis-accent-dim);
  transform: translateY(-1px);
}

.hr-hint {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.45rem;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-jarvis-accent);
  margin: 0;
  animation: hint-bob 2.4s ease-in-out infinite;
}

@keyframes hint-bob {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(4px); }
}

/* ── CONTENT PANEL ───────────────────────────────────────────── */
#content-panel {
  position: absolute;
  right: 0;
  top: 0;
  width: 52%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 5% 0 4%;
  opacity: 0;
  pointer-events: none;
  will-change: opacity;
}

#sec-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 4%;
  display: flex;
  align-items: baseline;
  gap: 0.3rem;
  font-size: 0.7rem;
  font-variant-numeric: tabular-nums;
  color: var(--color-jarvis-muted);
}

#sec-num {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-jarvis-accent);
  transition: color 0.3s;
}

.sep { opacity: 0.35; }

/* ── CONTENT CARDS ───────────────────────────────────────────── */
.c-card {
  position: absolute;
  width: calc(100% - 9%);
  opacity: 0;
  transform: translateY(48px);
  transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
}

.c-card[data-state="active"] {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.c-card[data-state="prev"] {
  opacity: 0;
  transform: translateY(-48px);
}

.c-card[data-state="next"] {
  opacity: 0;
  transform: translateY(48px);
}

.c-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-jarvis-accent);
  margin: 0 0 0.75rem;
}

.c-title {
  font-size: clamp(1.8rem, 3.2vw, 2.6rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #fff;
  line-height: 1.15;
  margin: 0 0 1.2rem;
  white-space: pre-line;
}

.c-body {
  font-size: clamp(0.82rem, 1.3vw, 0.95rem);
  color: var(--color-jarvis-muted);
  line-height: 1.7;
  margin: 0 0 1.75rem;
  max-width: 44ch;
}

.c-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.c-chips li {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  padding: 0.3rem 0.85rem;
  border-radius: 999px;
  border: 1px solid rgba(240, 122, 31, 0.3);
  color: var(--color-jarvis-glow);
  background: rgba(240, 122, 31, 0.06);
}

/* ── DOT NAV ─────────────────────────────────────────────────── */
#dot-nav {
  position: absolute;
  right: 2rem;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 20;
  opacity: 0;
  will-change: opacity;
}

.dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  border: 1.5px solid rgba(240, 122, 31, 0.35);
  background: transparent;
  cursor: pointer;
  transition: background 0.3s, border-color 0.3s, transform 0.3s;
  padding: 0;
}

.dot.active {
  background: var(--color-jarvis-accent);
  border-color: var(--color-jarvis-accent);
  transform: scale(1.4);
}

/* ── TRUST FOOTER SECTION ────────────────────────────────────── */
#trust-section {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 6rem 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  background: #020202;
}

.ts-inner {
  max-width: 560px;
  text-align: center;
}

.ts-logo {
  margin-bottom: 1.5rem;
  opacity: 0.7;
}

.ts-title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #fff;
  margin: 0 0 1rem;
}

.ts-body {
  font-size: 0.9375rem;
  color: var(--color-jarvis-muted);
  line-height: 1.7;
  margin: 0 0 2rem;
}

.ts-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}

.ts-links a {
  font-size: 0.8rem;
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--color-jarvis-muted);
  text-decoration: none;
  transition: color 0.2s, border-color 0.2s;
}
.ts-links a:hover {
  color: #fff;
  border-color: rgba(240, 122, 31, 0.4);
}

.ts-waitlist-btn {
  background: var(--color-jarvis-accent) !important;
  color: #fff !important;
  border-color: transparent !important;
  font-weight: 600;
}

/* ── MOBILE FALLBACK ─────────────────────────────────────────── */
@media (max-width: 768px) {
  #hero-left  { left: 4%; max-width: 180px; }
  #hero-right { right: 4%; max-width: 180px; }
  .hl-name    { font-size: 2.5rem; }
  #content-panel { width: 100%; padding: 0 6% 0 6%; }
  #visual-panel  { height: 42vh; }
  #dot-nav       { display: none; }
}
</style>

<script>
(() => {
  const stage    = document.getElementById("scroll-stage") as HTMLElement;
  const vPanel   = document.getElementById("visual-panel") as HTMLElement;
  const hLeft    = document.getElementById("hero-left") as HTMLElement;
  const hRight   = document.getElementById("hero-right") as HTMLElement;
  const cPanel   = document.getElementById("content-panel") as HTMLElement;
  const dotNav   = document.getElementById("dot-nav") as HTMLElement;
  const secNum   = document.getElementById("sec-num") as HTMLElement;
  const iframe   = document.getElementById("jarvis-iframe") as HTMLIFrameElement;
  const header   = document.getElementById("site-header") as HTMLElement;
  const dots     = Array.from(dotNav.querySelectorAll<HTMLElement>(".dot"));
  const cards    = Array.from(document.querySelectorAll<HTMLElement>(".c-card"));
  const N        = cards.length;

  // Scroll stage constants (must match STAGE_UNITS in frontmatter: 2 + N)
  const MORPH_START    = 1.0; // scrollUnit at which morph begins
  const SECTIONS_START = 2.0; // scrollUnit at which sections start
  const STAGE_UNITS    = SECTIONS_START + N;

  let currentSection  = -1;
  let rafPending      = false;
  let velTimer: ReturnType<typeof setTimeout> | null = null;
  let lastScrollY     = window.scrollY;
  let isSpeaking      = false;

  // ── Helpers ─────────────────────────────────────────────────────
  const clamp   = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));
  const eio     = (t: number) => t < 0.5 ? 2*t*t : -1+(4-2*t)*t; // ease-in-out
  const lerp    = (a: number, b: number, t: number) => a + (b - a) * t;

  function postMode(speaking: boolean) {
    iframe?.contentWindow?.postMessage(
      { type: "jarvis-visual-mode", payload: { speakModeOn: true, conversationHidden: true, isSpeaking: speaking } },
      "*"
    );
  }

  iframe?.addEventListener("load", () => postMode(false));

  // ── Main update — runs inside rAF so it's synced to the display refresh ──
  function update() {
    rafPending = false;

    const stageTop    = stage.getBoundingClientRect().top + window.scrollY;
    const maxScroll   = (STAGE_UNITS - 1) * window.innerHeight;
    const scrollInto  = clamp(window.scrollY - stageTop, 0, maxScroll);
    const scrollUnit  = scrollInto / window.innerHeight;

    // Header: become solid after hero
    header?.classList.toggle("scrolled", scrollUnit > 0.75);

    // ── Morph factor 0 (full) → 1 (side panel) ──────────────────
    const rawMorph = clamp((scrollUnit - MORPH_START) / 1.0, 0, 1);
    const morphT   = eio(rawMorph);

    // Visual panel clips from 100% → 48% using clip-path (compositor-only, no reflow)
    const clipPct = lerp(100, 48, morphT);
    vPanel.style.clipPath = `inset(0 ${100 - clipPct}% 0 0)`;

    // Hero text fades and slides apart
    const heroAlpha = clamp(1 - morphT * 2.2, 0, 1);
    const heroSlide = morphT * 60;
    hLeft.style.opacity  = String(heroAlpha);
    hLeft.style.transform  = `translateY(-50%) translateX(${-heroSlide}px)`;
    hRight.style.opacity = String(heroAlpha);
    hRight.style.transform = `translateY(-50%) translateX(${heroSlide}px)`;

    // Content panel fades in
    const contentAlpha = clamp((morphT - 0.35) / 0.65, 0, 1);
    cPanel.style.opacity       = String(contentAlpha);
    cPanel.style.pointerEvents = contentAlpha > 0.2 ? "auto" : "none";
    dotNav.style.opacity       = String(contentAlpha);

    // ── Section switching ────────────────────────────────────────
    const secFloat  = scrollUnit - SECTIONS_START;
    const rawIdx    = Math.floor(secFloat);
    const newSection = clamp(rawIdx, 0, N - 1);

    if (newSection !== currentSection) {
      currentSection = newSection;

      cards.forEach((card, i) => {
        if (i === currentSection)     card.dataset.state = "active";
        else if (i < currentSection) card.dataset.state = "prev";
        else                          card.dataset.state = "next";
      });

      dots.forEach((d, i) => d.classList.toggle("active", i === currentSection));
      if (secNum) secNum.textContent = String(currentSection + 1).padStart(2, "0");
    }
  }

  // ── Scroll handler — schedules a single rAF per frame ────────────
  function onScroll() {
    const vel = Math.abs(window.scrollY - lastScrollY);
    lastScrollY = window.scrollY;

    if (vel > 1 && !isSpeaking) {
      isSpeaking = true;
      postMode(true);
    }
    if (velTimer) clearTimeout(velTimer);
    velTimer = setTimeout(() => {
      isSpeaking = false;
      postMode(false);
    }, 450);

    // Coalesce multiple scroll events in the same frame into one update()
    if (!rafPending) {
      rafPending = true;
      requestAnimationFrame(update);
    }
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  update();

  // ── Dot nav click ────────────────────────────────────────────────
  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      const stageTop = stage.getBoundingClientRect().top + window.scrollY;
      const target   = stageTop + (SECTIONS_START + i + 0.05) * window.innerHeight;
      window.scrollTo({ top: target, behavior: "smooth" });
    });
  });

  // Init first card state
  cards[0]?.setAttribute("data-state", "active");
  cards.slice(1).forEach(c => c.setAttribute("data-state", "next"));
  dots[0]?.classList.add("active");
})();
</script>
