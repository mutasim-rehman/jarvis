---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Account" description="Sign in to JARVIS.">
  <main class="auth-page">
    <div class="auth-card">
      <div class="auth-brand">
        <span class="auth-logo" aria-hidden="true">J</span>
        <h1>Sign in to JARVIS</h1>
      </div>
      <p id="account-status" class="auth-subtitle">Loading…</p>

      <div id="signed-out" class="auth-actions hidden">
        <button type="button" id="signin-google" class="auth-oauth-btn auth-oauth-google">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span data-label>Continue with Google</span>
        </button>
        <button type="button" id="signin-github" class="auth-oauth-btn auth-oauth-github">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <span data-label>Continue with GitHub</span>
        </button>
      </div>

      <div id="signed-in" class="hidden auth-signed-in">
        <p id="account-email" class="auth-subtitle"></p>
        <a href="/onboarding" class="auth-link">Edit preferences</a>
        <button type="button" id="signout" class="auth-primary-btn">Sign out</button>
      </div>

      <p id="account-error" class="auth-error hidden"></p>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(240, 122, 31, 0.35), transparent 55%),
      var(--color-jarvis-bg);
  }
  .auth-card {
    width: 100%;
    max-width: 420px;
    padding: 2rem 1.75rem;
    border-radius: 16px;
    border: 1px solid #2a1a10;
    background: linear-gradient(165deg, #141414 0%, #0d0d0d 45%, #0a0a0a 100%);
    box-shadow: 0 0 0 1px rgba(240, 122, 31, 0.08), 0 24px 48px rgba(0, 0, 0, 0.55);
  }
  .auth-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.5rem;
  }
  .auth-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-jarvis-accent), var(--color-jarvis-accent-dim));
    color: #050505;
    font-weight: 800;
    font-size: 1.15rem;
  }
  .auth-card h1 {
    margin: 0;
    font-size: 1.5rem;
    color: var(--color-jarvis-fg);
  }
  .auth-subtitle {
    color: var(--color-jarvis-muted);
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0 0 1.25rem;
  }
  .auth-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .auth-oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
  }
  .auth-oauth-btn:disabled {
    opacity: 0.65;
    cursor: wait;
  }
  .auth-oauth-google {
    border: 1px solid #3d3d3d;
    background: #f7efe8;
    color: #1a1a1a;
  }
  .auth-oauth-github {
    border: 1px solid #2a1a10;
    background: #111;
    color: #f7efe8;
  }
  .auth-primary-btn {
    margin-top: 0.75rem;
    padding: 0.65rem 1.1rem;
    border-radius: 10px;
    border: none;
    background: linear-gradient(180deg, var(--color-jarvis-accent), var(--color-jarvis-accent-dim));
    color: #050505;
    font-weight: 600;
    cursor: pointer;
  }
  .auth-link {
    color: var(--color-jarvis-accent);
    font-size: 0.9rem;
  }
  .auth-error {
    margin-top: 1rem;
    color: #ff9b6a;
    font-size: 0.88rem;
  }
  .auth-signed-in {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .hidden {
    display: none !important;
  }
</style>

<script>
  import { getSupabase, isSupabaseConfigured } from "../lib/supabaseClient";

  const status = document.getElementById("account-status");
  const out = document.getElementById("signed-out");
  const inn = document.getElementById("signed-in");
  const emailEl = document.getElementById("account-email");
  const errEl = document.getElementById("account-error");
  let busyProvider: string | null = null;

  function setBusy(provider: string | null) {
    busyProvider = provider;
    for (const id of ["signin-google", "signin-github"] as const) {
      const btn = document.getElementById(id);
      if (!btn) continue;
      const label = btn.querySelector("[data-label]");
      const isBusy = provider === id.replace("signin-", "");
      btn.toggleAttribute("disabled", provider !== null);
      if (label) {
        label.textContent = isBusy
          ? "Opening in browser…"
          : id === "signin-google"
            ? "Continue with Google"
            : "Continue with GitHub";
      }
    }
  }

  async function refresh() {
    if (!isSupabaseConfigured()) {
      if (status) status.textContent = "Sign-in is not configured on this deployment.";
      return;
    }
    const supabase = getSupabase();
    if (!supabase) return;
    const { data } = await supabase.auth.getSession();
    if (!data.session) {
      if (status) status.textContent = "One account for desktop, hub, and mobile.";
      out?.classList.remove("hidden");
      inn?.classList.add("hidden");
      return;
    }
    if (status) status.textContent = "You are signed in.";
    out?.classList.add("hidden");
    inn?.classList.remove("hidden");
    if (emailEl) emailEl.textContent = data.session.user.email ?? data.session.user.id;
  }

  async function signIn(provider: "google" | "github") {
    const supabase = getSupabase();
    if (!supabase) return;
    setBusy(provider);
    if (errEl) errEl.classList.add("hidden");
    try {
      const redirectTo = `${window.location.origin}/auth/callback`;
      const { error } = await supabase.auth.signInWithOAuth({ provider, options: { redirectTo } });
      if (error) throw error;
    } catch (e) {
      if (errEl) {
        errEl.textContent = e instanceof Error ? e.message : "Sign-in failed";
        errEl.classList.remove("hidden");
      }
      setBusy(null);
    }
  }

  document.getElementById("signin-google")?.addEventListener("click", () => void signIn("google"));
  document.getElementById("signin-github")?.addEventListener("click", () => void signIn("github"));

  document.getElementById("signout")?.addEventListener("click", async () => {
    const supabase = getSupabase();
    if (supabase) await supabase.auth.signOut();
    window.location.href = "/";
  });

  void refresh();
</script>
