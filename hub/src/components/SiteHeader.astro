---
import { site } from "../config/site";
import AuthNav from "./AuthNav.astro";

interface Props {
  heroHeader?: boolean;
}
const { heroHeader = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { href: "/", label: "Home", match: (p: string) => p === "/" },
  { href: "/privacy", label: "Privacy", match: (p: string) => p === "/privacy" },
  { href: "/terms", label: "Terms", match: (p: string) => p === "/terms" },
  { href: "/waitlist", label: "Waitlist", match: (p: string) => p === "/waitlist" },
];
---

<header id="site-header" class:list={["site-header", heroHeader && "hero-mode"]}>
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src="/favicon.svg" alt="" width="26" height="26" />
      <span>{site.name}</span>
    </a>

    <nav class="header-nav" aria-label="Site">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={["header-link", item.match(path) && "active"]}
            aria-current={item.match(path) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-right">
      <AuthNav />
      {
        path !== "/waitlist" ? (
          <a href="/waitlist" class="header-cta">
            Join waitlist
          </a>
        ) : null
      }
      {
        site.githubUrl ? (
          <a
            href={site.githubUrl}
            class="header-btn"
            rel="noopener noreferrer"
            target="_blank"
          >
            Source
          </a>
        ) : null
      }
    </div>
  </div>
</header>
