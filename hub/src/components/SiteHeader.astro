---
import { site } from "../config/site";

const nav = [
  { href: "/#demo", label: "Demo" },
  { href: "/#features", label: "Features" },
  { href: "/#architecture", label: "How it works" },
  { href: "/#integrations", label: "Integrations" },
  { href: "/#safety", label: "Safety" },
  { href: "/#faq", label: "FAQ" },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-jarvis-bg/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="group flex items-center gap-2.5 font-semibold tracking-tight text-white">
      <img src="/favicon.svg" alt="" width="28" height="28" class="h-7 w-7" />
      <span>{site.name}</span>
    </a>
    <nav class="hidden items-center gap-8 text-sm text-jarvis-muted md:flex" aria-label="Main">
      {nav.map((item) => (
        <a
          href={item.href}
          class="transition-colors hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3 text-sm">
      <a
        href="/privacy"
        class:list={[
          "hidden sm:inline transition-colors",
          path === "/privacy" || path === "/terms"
            ? "text-white"
            : "text-jarvis-muted hover:text-white",
        ]}
      >
        Legal
      </a>
      {
        site.githubUrl ? (
          <a
            href={site.githubUrl}
            class="rounded-lg border border-white/10 px-3 py-1.5 text-jarvis-muted transition hover:border-jarvis-accent/50 hover:text-white"
            rel="noopener noreferrer"
            target="_blank"
          >
            Source
          </a>
        ) : null
      }
    </div>
  </div>
</header>
