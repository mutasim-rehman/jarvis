---
import { site } from "../config/site";

interface Props {
  heroHeader?: boolean;
}
const { heroHeader = false } = Astro.props;
const path = Astro.url.pathname;
---

<header id="site-header" class:list={["site-header", heroHeader && "hero-mode"]}>
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src="/favicon.svg" alt="" width="26" height="26" />
      <span>{site.name}</span>
    </a>

    <div class="header-right">
      <a
        href="/privacy"
        class:list={[
          "header-link",
          path === "/privacy" || path === "/terms" ? "active" : "",
        ]}
      >
        Legal
      </a>
      {
        site.githubUrl ? (
          <a
            href={site.githubUrl}
            class="header-btn"
            rel="noopener noreferrer"
            target="_blank"
          >
            Source
          </a>
        ) : null
      }
    </div>
  </div>
</header>
