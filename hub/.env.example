# Production site URL (no trailing slash) — used in astro.config.mjs at build time
PUBLIC_SITE_URL=https://your-domain.com

# Shown on legal pages and footer
PUBLIC_CONTACT_EMAIL=jarvis.mutasim@gmail.com

# Optional: show "Source" link in header when set
# PUBLIC_GITHUB_URL=https://github.com/your-org/jarvis

# Waitlist — Google Sheets (service account must have Editor access on the sheet)
Google_Service_Account_JSON={"type":"service_account",...}
WATLIST_SHEET_ID=your_google_sheet_id

# SMTP — confirmation emails sent on waitlist signup
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_APP_NAME=JARVIS
